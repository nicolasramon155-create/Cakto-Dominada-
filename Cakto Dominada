    <script>
        // FAQ Accordion
        document.querySelectorAll('.faq-question').forEach(question => {
            question.addEventListener('click', () => {
                const answer = question.nextElementSibling;
                const icon = question.querySelector('i');
                
                // Toggle active class
                answer.classList.toggle('active');
                
                // Change icon
                if (answer.classList.contains('active')) {
                    icon.classList.remove('fa-chevron-down');
                    icon.classList.add('fa-chevron-up');
                } else {
                    icon.classList.remove('fa-chevron-up');
                    icon.classList.add('fa-chevron-down');
                }
            });
        });
        
        // Smooth scroll para links internos
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                
                const targetId = this.getAttribute('href');
                if (targetId === '#') return;
                
                const targetElement = document.querySelector(targetId);
                if (targetElement) {
                    window.scrollTo({
                        top: targetElement.offsetTop - 80,
                        behavior: 'smooth'
                    });
                }
            });
        });
        
        // Contador de oferta (opcional)
        function createCountdown() {
            // Implementar contador de tempo limitado se quiser
            console.log("Contador opcional para urgência");
        }
        
        // Tracking do botão de compra
        document.getElementById('buy-button-cakto').addEventListener('click', function() {
            // Adicionar tracking aqui (Facebook Pixel, Google Analytics, etc.)
            console.log("Redirecionando para checkout da Cakto");
            
            // Exemplo de tracking com gtag
            if (typeof gtag !== 'undefined') {
                gtag('event', 'conversion', {
                    'send_to': 'AW-123456789/AbC-D_efG-h12',
                    'value': 197.00,
                    'currency': 'BRL',
                    'transaction_id': ''
                });
            }
        });
        
        // Inicializar
        document.addEventListener('DOMContentLoaded', function() {
            createCountdown();
        });
    </script>
